Checks: '-*,clang-diagnostic-*,clang-analyzer-*,-clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,bugprone-*,-bugprone-easily-swappable-parameters,cert-*,readability-*,-readability-magic-numbers,-readability-identifier-length'

CheckOptions:
  - key: readability-function-cognitive-complexity.Threshold
    value: '10'

HeaderFilterRegex: '.*'
WarningsAsErrors: ''